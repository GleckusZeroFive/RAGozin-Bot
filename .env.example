# Telegram
TELEGRAM_BOT_TOKEN=your_token_here

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ragbot
POSTGRES_USER=ragbot
POSTGRES_PASSWORD=ragbot_secret

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# LLM (Claude через прокси на хосте)
# Прокси запускается отдельно: cd proxy && bash start.sh
CLAUDE_PROXY_URL=http://host.docker.internal:8200/v1
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Embeddings (локальная модель sentence-transformers)
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DEVICE=cpu
EMBEDDING_DIMENSION=1024

# RAG
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
CHUNKER_MODE=advanced
MIN_CHUNK_SIZE=50
RETRIEVER_TOP_K=5
RETRIEVER_SCORE_THRESHOLD=0.5

# Embedding batching
EMBEDDING_BATCH_MAX_ITEMS=256

# OCR (Tesseract)
OCR_ENABLED=true
OCR_LANGUAGES=rus+spa+eng
OCR_TEXT_THRESHOLD=50

# Speech-to-Text (голосовые сообщения, faster-whisper)
STT_ENABLED=true
WHISPER_MODEL_SIZE=small
WHISPER_LANGUAGE=ru
WHISPER_MAX_DURATION=60

# Uploads
MAX_FILE_SIZE_MB=20

# Law Corpus (внешний сервис Rus_Law_Parser)
LAW_CORPUS_ENABLED=false
LAW_API_URL=http://localhost:8100
LAW_CORPUS_TOP_K=5
LAW_CORPUS_WEIGHT=0.7
